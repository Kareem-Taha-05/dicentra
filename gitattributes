# Auto-detect text files and normalise line endings
* text=auto

# Force LF for Python source
*.py text eol=lf

# Force LF for config and docs
*.md  text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.txt text eol=lf
*.cfg text eol=lf
*.ini text eol=lf

# Binary files — do not touch
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.dcm binary
*.nii binary
*.gz  binary
